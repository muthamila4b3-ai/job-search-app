# Backend Environment Variables Template for Render Deployment
# Copy this to `.env` for local development
# For Render deployment, set these as environment secrets in your Render dashboard

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (MySQL)
DB_HOST=your-mysql-host.render.com
DB_USER=your-db-user
DB_PASSWORD=your-secure-db-password
DB_NAME=job_search

# Security - Generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# CORS Configuration - Set to your frontend domain in production
CORS_ORIGIN=https://your-frontend-domain.com

# Production Notes:
# - Set NODE_ENV=production for production deployment
# - Use a strong JWT_SECRET (at least 32 characters)
# - Set CORS_ORIGIN to your actual frontend domain (no trailing slash)
# - Database credentials should be for your production MySQL instance
# - All sensitive values should be set as Render environment secrets, not in this file
